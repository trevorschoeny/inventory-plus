{
  "schemaVersion": 1,
  "id": "inventoryplus",
  "version": "${version}",
  "name": "Inventory Plus",
  "description": "Client-side inventory quality-of-life: auto-restock, auto tool switch, sorting, move matching, locked slots, column cycler. Installs on any server.",
  "authors": ["trevorschoeny"],
  "license": "MIT",
  "environment": "client",
  "mixins": [
    "inventoryplus.mixins.json"
  ],
  "entrypoints": {
    "client": ["com.trevorschoeny.inventoryplus.InventoryPlusClient"],
    "modmenu": ["com.trevorschoeny.inventoryplus.config.IPConfigModMenu"]
  },
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "~1.21",
    "menukit": ">=2.0.0",
    "keybindery": ">=1.0.2"
  }
}
